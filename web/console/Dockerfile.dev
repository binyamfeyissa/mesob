FROM node:22-alpine
WORKDIR /app
# Install deps first (cached layer — only re-runs when package.json changes)
COPY package*.json ./
RUN npm config set fetch-timeout 600000 \
 && npm config set fetch-retry-mintimeout 20000 \
 && npm config set fetch-retry-maxtimeout 120000 \
 && npm config set fetch-retries 5 \
 && npm install --prefer-offline || npm install
# Source is mounted as a volume at runtime — no COPY needed
EXPOSE 3000
# WATCHPACK_POLLING is required for HMR file-watching to work inside
# Docker on macOS (inotify doesn't propagate across the bind mount)
ENV WATCHPACK_POLLING=true
CMD ["sh", "-c", "[ -f node_modules/.bin/next ] || npm install && npm run dev"]
